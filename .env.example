# API Gateway URL for serverless Lambda backend (no trailing slash)
# Get this from your AWS API Gateway console
# Format: https://<api-id>.execute-api.<region>.amazonaws.com
# Example: https://abc123xyz.execute-api.us-east-1.amazonaws.com
VITE_API_BASE_URL=

# If your API Gateway has a custom domain:
# VITE_API_BASE_URL=https://api.yourdomain.com
